<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="<%= it.description %>" />
        <title><%= it.title %></title>

        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="canonical" href="<%= it.canonicalUrl %>" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="<%= it.canonicalUrl %>" />
        <meta property="og:title" content="<%= it.title %>" />
        <meta property="og:description" content="<%= it.description %>" />
        <meta property="og:site_name" content="VList" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content="<%= it.canonicalUrl %>" />
        <meta name="twitter:title" content="<%= it.title %>" />
        <meta name="twitter:description" content="<%= it.description %>" />

        <!-- Additional SEO -->
        <meta name="author" content="Floor IO" />
        <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        <meta name="keywords" content="virtual list, virtual scroll, infinite scroll, react virtual list, performance, web components, javascript library, zero dependencies" />

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            "name": "VList",
            "applicationCategory": "DeveloperApplication",
            "operatingSystem": "Web",
            "url": "<%= it.canonicalUrl %>",
            "description": "<%= it.description %>",
            "author": {
                "@type": "Organization",
                "name": "Floor IO",
                "url": "https://floor.io"
            },
            "offers": {
                "@type": "Offer",
                "price": "0",
                "priceCurrency": "USD"
            },
            "softwareVersion": "<%= it.version %>",
            "license": "https://opensource.org/licenses/MIT",
            "programmingLanguage": {
                "@type": "ComputerLanguage",
                "name": "TypeScript"
            }
        }
        </script>

        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "VList",
            "url": "<%= it.canonicalUrl %>",
            "potentialAction": {
                "@type": "SearchAction",
                "target": "<%= it.canonicalUrl %>/docs/?q={search_term_string}",
                "query-input": "required name=search_term_string"
            }
        }
        </script>

        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [{
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "<%= it.canonicalUrl %>"
            }]
        }
        </script>

        <link rel="stylesheet" href="/styles/tokens.css" />
        <link rel="stylesheet" href="/styles/syntax.css" />
        <link rel="stylesheet" href="/styles/shell.css" />
        <link rel="stylesheet" href="/styles/ui.css" />
        <link rel="stylesheet" href="/styles/homepage.css" />
        <link rel="stylesheet" href="/dist/vlist.css" />

        <!-- Theme: apply before paint to prevent flash -->
        <script>
            (function () {
                var t = localStorage.getItem("vlist-theme-mode");
                if (!t)
                    t = window.matchMedia("(prefers-color-scheme: light)")
                        .matches
                        ? "light"
                        : "dark";
                document.documentElement.setAttribute("data-theme-mode", t);
            })();
        </script>
    </head>
    <body class="no-sidebar">
        <header class="header">
            <div class="header__inner">
                <a href="/" class="header__logo">VList</a>
                <nav class="header__nav">
                    <% it.navItems.forEach(function(item) { %>
                    <a href="<%= item.href %>"<% if (item.external) { %> target="_blank"<% } %>><%= item.label %></a>
                    <% }); %>
                </nav>
                <button class="header__theme" id="theme-toggle" aria-label="Toggle theme">
                    <svg class="header__theme-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </svg>
                    <svg class="header__theme-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                </button>
                <button class="header__hamburger" id="hamburger" aria-label="Toggle menu">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <rect y="3" width="20" height="2" rx="1" />
                        <rect y="9" width="20" height="2" rx="1" />
                        <rect y="15" width="20" height="2" rx="1" />
                    </svg>
                </button>
            </div>
        </header>

        <nav class="dropdown" id="dropdown">
            <% it.navItems.forEach(function(item) { %>
            <a href="<%= item.href %>"<% if (item.external) { %> target="_blank"<% } %>><%= item.label %></a>
            <% }); %>
        </nav>

        <div class="container-hero">
            <!-- ========================================================
                 Hero
                 ======================================================== -->

            <section class="hero">
                <h1 class="hero__name">VList</h1>
                <p class="hero__tagline">
                    Ultra-efficient virtual list with constant memory.
                    Dimension-agnostic architecture. Tree-shakeable features. 120+ FPS sustained.
                </p>

                <div class="hero__badges">
                    <span class="badge badge--accent">v<%= it.version %></span>
                    <span class="badge"><%= it.bundleSize %> KB gzipped</span>
                    <span class="badge">Zero Dependencies</span>
                    <span class="badge badge--accent">0.1-0.3 MB @ 1M items</span>
                    <span class="badge">120+ FPS sustained</span>
                </div>

                <div class="hero__actions">

                    <a href="/examples/" class="btn btn--primary">
                        Try Examples →
                    </a>
                    <a href="/docs/" class="btn btn--primary">
                        Read the docs →
                    </a>
                    <a href="/benchmarks/" class="btn btn--primary">
                        Run the Benchmarks →
                    </a>
                    <a href="https://github.com/floor/vlist" class="btn btn--ghost" target="_blank">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                        </svg>
                        GitHub
                    </a>
                </div>

                <!-- ========================================================
                 Install
                 ======================================================== -->

                <div class="install">
                    <div class="install__cmd">
                        <span>npm install @floor/vlist</span>
                    </div>
                </div>


            </section>
        </div>
        <div class="container">


            <!-- ========================================================
                 Quick Start
                 ======================================================== -->

            <section class="section">
                <h2 class="section__title">Try It</h2>
                <p class="section__desc">10 lines of code, 100,000 items. Scroll the live list on the right.</p>
                <div class="quickstart">
                    <div class="quickstart__code ui-card code">
                        <pre><%~ it.quickstartCode %></pre>
                    </div>
                    <div class="quickstart__demo">
                        <div class="quickstart__demo-header">
                            <span class="quickstart__demo-label">Live — 100,000 users</span>
                        </div>
                        <div id="quickstart-list" class="quickstart__demo-list"></div>
                    </div>
                </div>
            </section>

            <!-- ========================================================
                 Performance Highlights
                 ======================================================== -->

            <section class="section">
                <h2 class="section__title">Less Weight, More Speed</h2>
                <p class="section__desc">Verified benchmarks show VList's exceptional efficiency. All tests run live in your browser.</p>
                <div class="features">
                    <div class="ui-card ui-card--xl feature">
                        <div class="feature__name">Constant Memory</div>
                        <div class="feature__desc">
                            Just 0.24 MB at 10K items, scales to 0.1-0.3 MB even at 1M+ items
                        </div>
                    </div>
                    <div class="ui-card ui-card--xl feature">
                        <div class="feature__name">Fast Renders</div>
                        <div class="feature__desc">
                            Initial render in ~8.5ms, optimized for instant user feedback
                        </div>
                    </div>
                    <div class="ui-card ui-card--xl feature">
                        <div class="feature__name">Smooth Scrolling</div>
                        <div class="feature__desc">
                            Perfect 120 FPS sustained performance, buttery smooth at any scale
                        </div>
                    </div>
                </div>
                <div style="text-align: center; margin-top: 32px;">
                    <a href="/benchmarks" class="btn btn--ghost">
                        View Full Comparison →
                    </a>
                </div>
            </section>

            <!-- ========================================================
                 Features
                 ======================================================== -->

            <section class="section">
                <h2 class="section__title">What's Inside</h2>
                <p class="section__desc">Every feature is tree-shakeable — import only what you need.</p>
                <div class="features">
                    <div class="ui-card feature">
                        <span class="feature__icon">⚡</span>
                        <div class="feature__name">Blazing Fast</div>
                        <div class="feature__desc">
                            DOM recycling, RAF batching, O(log n) lookups — 120+ FPS sustained
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">💾</span>
                        <div class="feature__name">Constant Memory</div>
                        <div class="feature__desc">
                            Just 0.24 MB at 10K items, scales to 0.1-0.3 MB even at 1M+ items — true O(1) memory complexity
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">↔️</span>
                        <div class="feature__name">Dimension Agnostic</div>
                        <div class="feature__desc">
                            Vertical &amp; horizontal orientations with semantic API — grid, groups, all features work both ways
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">📏</span>
                        <div class="feature__name">Variable Sizes</div>
                        <div class="feature__desc">
                            Per-item size function with DOM measurement support
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">♾️</span>
                        <div class="feature__name">Infinite Scroll</div>
                        <div class="feature__desc">
                            Async adapter with placeholders, velocity-aware loading
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">🔀</span>
                        <div class="feature__name">Reverse Mode</div>
                        <div class="feature__desc">
                            Chat UIs — start at bottom, prepend history, auto-scroll
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">☑️</span>
                        <div class="feature__name">Selection</div>
                        <div class="feature__desc">
                            Single &amp; multi-select with full keyboard navigation
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">🔲</span>
                        <div class="feature__name">Grid, Table &amp; Masonry</div>
                        <div class="feature__desc">
                            Virtualized 2D grid, data table, and masonry layouts — all orientations
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">📌</span>
                        <div class="feature__name">Sticky Headers</div>
                        <div class="feature__desc">
                            Grouped lists with sticky headers in any orientation
                        </div>
                    </div>
                    <div class="ui-card feature">
                        <span class="feature__icon">🗜️</span>
                        <div class="feature__name">Compression</div>
                        <div class="feature__desc">
                            Handle millions of items by compressing scroll space
                        </div>
                    </div>
                </div>
            </section>

            <!-- ========================================================
                 Examples Examples
                 ======================================================== -->

            <section class="section">
                <h2 class="section__title">Showcase with Source</h2>
                <p class="section__desc">Interactive examples with full source code. Run them, read them, copy them.</p>
                <% it.exampleGroups.forEach(function(group) { %>
                <div class="overview__section">
                    <div class="overview__section-title"><%= group.label %></div>
                    <div class="overview__grid">
                        <% group.items.forEach(function(item) { %>
                        <a href="/examples/<%= item.slug %>" class="ui-card ui-card--interactive overview__card">
                            <div class="overview__card-title"><%= item.name %></div>
                            <div class="overview__card-desc"><%= item.desc %></div>
                            <% if (item.features && item.features.length > 0) { %>
                            <div class="overview__chips"><% item.features.forEach(function(f) { %><span class="overview__chip"><%= f %></span><% }); %></div>
                            <% } %>
                        </a>
                        <% }); %>
                    </div>
                </div>
                <% }); %>
            </section>

            <!-- ========================================================
                 Explore
                 ======================================================== -->

            <section class="section">
                <h2 class="section__title">Learn More</h2>
                <p class="section__desc">Docs, tutorials, and benchmarks to get the most out of VList.</p>
                <div class="nav-grid">
                    <a href="/examples/" class="ui-card ui-card--interactive nav-card">
                        <div class="nav-card__title">Examples</div>
                        <div class="nav-card__desc">
                            13 interactive examples — from basic lists to million-item stress tests
                        </div>
                        <span class="nav-card__link">Browse examples →</span>
                    </a>
                    <a href="/docs/" class="ui-card ui-card--interactive nav-card">
                        <div class="nav-card__title">Documentation</div>
                        <div class="nav-card__desc">
                            API reference, configuration, events, methods, styling, and more
                        </div>
                        <span class="nav-card__link">Read docs →</span>
                    </a>
                    <a href="/benchmarks/" class="ui-card ui-card--interactive nav-card">
                        <div class="nav-card__title">Benchmarks</div>
                        <div class="nav-card__desc">
                            Live performance tests — scroll FPS, render time, memory stability, bundle size
                        </div>
                        <span class="nav-card__link">Run benchmarks →</span>
                    </a>
                    <a href="/tutorials/" class="ui-card ui-card--interactive nav-card">
                        <div class="nav-card__title">Tutorials</div>
                        <div class="nav-card__desc">
                            Step-by-step guides to learn vlist from beginner to advanced
                        </div>
                        <span class="nav-card__link">See →</span>
                    </a>
                </div>
            </section>
        </div>

        <!-- ============================================================
             Footer
             ============================================================ -->

        <footer>
            <div class="container">
                <div class="footer__links">
                    <a href="https://github.com/floor/vlist" target="_blank">GitHub</a>
                    <a href="https://www.npmjs.com/package/vlist" target="_blank">npm</a>
                    <% it.navItems.forEach(function(item) { %>
                    <% if (!item.external) { %>
                    <a href="<%= item.href %>"><%= item.label %></a>
                    <% } %>
                    <% }); %>
                </div>
                <p>
                    Built by <a href="https://floor.io" target="_blank">Floor IO</a>
                </p>
            </div>
        </footer>

        <script>
            (function () {
                var h = document.getElementById("hamburger");
                var d = document.getElementById("dropdown");
                if (!h) return;
                h.addEventListener("click", function () {
                    d.classList.toggle("dropdown--open");
                });
                d.addEventListener("click", function (e) {
                    if (e.target.closest("a"))
                        d.classList.remove("dropdown--open");
                });
            })();
        </script>

        <!-- ─── Theme toggle ─────────────────────────────────── -->

        <script>
            (function () {
                var btn = document.getElementById("theme-toggle");
                if (!btn) return;
                btn.addEventListener("click", function () {
                    var current = document.documentElement.getAttribute("data-theme-mode");
                    var next = current === "light" ? "dark" : "light";
                    document.documentElement.setAttribute("data-theme-mode", next);
                    localStorage.setItem("vlist-theme-mode", next);
                });
            })();
        </script>

        <!-- ─── Quick Start live demo ────────────────────────── -->

        <style>
            .qs-user {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 0 16px;
                height: 100%;
                border-bottom: 1px solid var(--border);
            }
            .qs-avatar {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                font-weight: 600;
                flex-shrink: 0;
            }
            .qs-name {
                font-size: 14px;
                font-weight: 500;
                color: var(--text);
                line-height: 1.3;
            }
            .qs-email {
                font-size: 12px;
                color: var(--text-muted);
                line-height: 1.3;
            }
        </style>
        <script type="module">
            import { vlist } from "/dist/index.js";

            const FIRST = ["James","Mary","Robert","Patricia","John","Jennifer","Michael","Linda","David","Elizabeth","William","Barbara","Richard","Susan","Joseph","Jessica","Thomas","Sarah","Christopher","Karen","Charles","Lisa","Daniel","Nancy","Matthew","Betty","Anthony","Margaret","Mark","Sandra","Donald","Ashley","Steven","Dorothy","Paul","Kimberly","Andrew","Emily","Joshua","Donna","Kenneth","Michelle","Kevin","Carol","Brian","Amanda","George","Melissa","Timothy","Deborah"];
            const LAST = ["Smith","Johnson","Williams","Brown","Jones","Garcia","Miller","Davis","Rodriguez","Martinez","Hernandez","Lopez","Gonzalez","Wilson","Anderson","Thomas","Taylor","Moore","Jackson","Martin","Lee","Perez","Thompson","White","Harris","Sanchez","Clark","Ramirez","Lewis","Robinson","Walker","Young","Allen","King","Wright","Scott","Torres","Nguyen","Hill","Flores"];
            const ROLES = ["Software Engineer","Senior Engineer","Staff Engineer","Designer","Product Manager","Data Analyst","DevOps Engineer","QA Engineer","Sales Representative","Marketing Specialist","Frontend Developer","Backend Developer","Fullstack Developer","UX Researcher","Security Analyst","Support Engineer"];
            const COMPANIES = ["Acme Corp","Globex","Initech","Umbrella","Stark Industries","Wayne Enterprises","Cyberdyne","Aperture Science","Massive Dynamic","Pied Piper","Hooli","Planet Express","Dunder Mifflin","Los Pollos Hermanos","Mesa Verde","Sterling Cooper"];
            const COLORS = ["#e53935","#d81b60","#8e24aa","#5e35b1","#3949ab","#1e88e5","#039be5","#00acc1","#00897b","#43a047","#7cb342","#fb8c00","#f4511e","#6d4c41","#ec407a","#ab47bc","#7e57c2","#42a5f5","#26c6da","#66bb6a"];

            const hash = (i, s) => { let h = 2166136261 ^ s; h = Math.imul(h ^ (i & 0xff), 16777619); h = Math.imul(h ^ ((i >> 8) & 0xff), 16777619); h = Math.imul(h ^ ((i >> 16) & 0xff), 16777619); return h >>> 0; };
            const pick = (arr, i, s) => arr[hash(i, s) % arr.length];

            // Relative luminance (WCAG 2.x) from a hex color → white or dark text
            function textColor(hex) {
                const r = parseInt(hex.slice(1, 3), 16) / 255;
                const g = parseInt(hex.slice(3, 5), 16) / 255;
                const b = parseInt(hex.slice(5, 7), 16) / 255;
                const toLinear = (c) => c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
                const L = 0.2126 * toLinear(r) + 0.7152 * toLinear(g) + 0.0722 * toLinear(b);
                return L > 0.179 ? "#1a1a2e" : "#fff";
            }

            function generateUsers(count) {
                return Array.from({ length: count }, (_, i) => {
                    const firstName = pick(FIRST, i, 1);
                    const lastName = pick(LAST, i, 2);
                    const bg = pick(COLORS, i, 4);
                    return {
                        id: i + 1,
                        firstName,
                        lastName,
                        avatar: firstName[0] + lastName[0],
                        avatarColor: bg,
                        textColor: textColor(bg),
                        role: pick(ROLES, i, 5),
                        company: pick(COMPANIES, i, 7),
                    };
                });
            }

            const list = vlist({
                container: "#quickstart-list",
                ariaLabel: "Users",
                item: {
                    height: 56,
                    template: (item) => `
                        <div class="qs-user">
                            <div class="qs-avatar" style="background:${item.avatarColor};color:${item.textColor}">${item.avatar}</div>
                            <div>
                                <div class="qs-name">${item.firstName} ${item.lastName}</div>
                                <div class="qs-email">${item.role} · ${item.company}</div>
                            </div>
                        </div>`,
                },
            }).build();

            list.setItems(generateUsers(100_000));
        </script>
    </body>
</html>
