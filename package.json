{
  "name": "vlist.io",
  "version": "0.2.6",
  "description": "vlist.io — documentation, examples, and benchamrks for the vlist library",
  "type": "module",
  "imports": {
    "vlist": "vlist",
    "vlist/*": "vlist/*"
  },
  "scripts": {
    "dev": "bun run build:examples && bun run build:bench && bun run --watch server.ts",
    "dev:full": "bun run build:examples && bun run build:bench && bun run build:examples:watch & bun run build:bench:watch & bun run --watch server.ts",
    "start": "bun run server.ts",
    "build:examples": "bun run examples/build.ts",
    "build:examples:watch": "bun run examples/build.ts --watch",
    "build:bench": "bun run benchmarks/build.ts",
    "build:bench:watch": "bun run benchmarks/build.ts --watch",
    "seed:benchmarks": "bun run scripts/seed-benchmarks.ts",
    "seed:books": "bun run scripts/seed-books.ts",
    "test": "bun test test/",
    "test:watch": "bun test --watch test/",
    "test:coverage": "NODE_ENV=production bun test --coverage test/",
    "typecheck": "tsc --noEmit",
    "deploy": "bun run scripts/deploy.ts",
    "deploy:staging": "bun run scripts/deploy.ts staging"
  },
  "dependencies": {
    "@legendapp/list": "3.0.0-beta.40",
    "@tanstack/react-virtual": "^3.13.18",
    "@tanstack/solid-virtual": "^3.13.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clusterize.js": "^0.18.1",
    "eta": "^4.5.1",
    "marked": "^17.0.1",
    "minisearch": "^7.2.0",
    "mongodb": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3",
    "react-window": "1.8.10",
    "solid-js": "^1.9.11",
    "virtua": "^0.48.6",
    "vlist": "file:../vlist",
    "vlist-react": "^1.6.0",
    "vlist-solidjs": "^1.6.0",
    "vlist-svelte": "^1.6.0",
    "vlist-vue": "^1.6.0",
    "vue": "^3.5.28",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/bun": "latest",
    "babel-preset-solid": "^1.9.10",
    "sass": "^1.85.0",
    "typescript": "^5.8.0"
  }
}
